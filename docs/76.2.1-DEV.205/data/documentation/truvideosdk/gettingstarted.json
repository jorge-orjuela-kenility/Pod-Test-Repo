{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/com.truvideo.TruvideoSdk\/documentation\/TruvideoSdk"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/truvideosdk\/gettingstarted"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/truvideosdk\/gettingstarted"]}],"metadata":{"images":[{"type":"icon","identifier":"architecture.jpg"}],"role":"sampleCode","modules":[{"name":"TruvideoSdk"}],"title":"Getting started with TruvideoSdk","roleHeading":"Sample Code"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"strong","inlineContent":[{"text":"TruVideo SDK","type":"text"}]},{"type":"text","text":" provides developers with a robust framework for managing secure user authentication, video workflows, and data management. It ensures reliable integration for video-centric applications on iOS."}]},{"inlineContent":[{"text":"This SDK includes methods for:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Authenticating users with API keys and payloads."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Managing session statuses, including checking for expiration and reinitialization."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow the steps below to integrate and authenticate with the SDK efficiently."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/\/ Generates an HMAC-SHA256 signature using the provided secret key.","    \/\/\/","    \/\/\/ - Parameter key: The secret key used to generate the signature.","    \/\/\/ - Returns: A hexadecimal string representing the HMAC-SHA256 signature.","    func toHMACSHA256(using key: String) -> String {","        let data = Data(self.utf8)","        let keyData = Data(key.utf8)","        var macData = Data(count: Int(CC_SHA256_DIGEST_LENGTH))","        ","        macData.withUnsafeMutableBytes { macBytes in","            data.withUnsafeBytes { dataBytes in","                keyData.withUnsafeBytes { keyBytes in","                    CCHmac(","                        CCHmacAlgorithm(kCCHmacAlgSHA256),","                        keyBytes.baseAddress,","                        keyData.count,","                        dataBytes.baseAddress,","                        data.count,","                        macBytes.baseAddress","                    )","                }","            }","        }","        ","        return macData.map { String(format: \"%02hhx\", $0) }.joined()","    }"]},{"level":2,"anchor":"How-to-authenticate","text":"How to authenticate","type":"heading"},{"inlineContent":[{"type":"text","text":"The authenticate method requires the following inputs:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"API Key"}],"type":"strong"},{"type":"text","text":": The API key associated with your account, required to authorize requests."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Payload","type":"text"}]},{"type":"text","text":": A payload generated by the generatePayload method containing device-specific information."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Signature"}],"type":"strong"},{"text":": An HMAC-SHA256 signature of the payload, created using a secret key.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"External ID (Optional)","type":"text"}]},{"type":"text","text":": An optional identifier for additional context in authentication."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The following example demonstrates how to use the authenticate method:","type":"text"}]},{"code":["    func authenticate() async throws {","        let payload = try TruvideoSdk.generatePayload()","        let signature = payload.toHMACSHA256(using: \"secretKey\")","        ","        try await TruvideoSdk.authenticate(","            apiKey: \"apiKey\",","            payload: \"payload\",","            signature: signature,","            externalId: \"externalId\"","        )","    }"],"type":"codeListing","syntax":"swift"},{"anchor":"How-to-clear-authentication","type":"heading","text":"How to clear authentication","level":2},{"syntax":"swift","code":["    func clearAuthentication() async throws {","        try TruvideoSdk.clearAuthentication()","    }"],"type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.truvideo.TruvideoSdk\/documentation\/TruvideoSdk\/GettingStarted","interfaceLanguage":"swift"},"sections":[],"references":{"doc://com.truvideo.TruvideoSdk/documentation/TruvideoSdk":{"type":"topic","abstract":[],"title":"TruvideoSdk","identifier":"doc:\/\/com.truvideo.TruvideoSdk\/documentation\/TruvideoSdk","url":"\/documentation\/truvideosdk","role":"collection","kind":"symbol"},"architecture.jpg":{"identifier":"architecture.jpg","alt":null,"type":"image","variants":[{"url":"\/images\/architecture.jpg","traits":["1x","light"]}]}},"variantOverrides":[{"patch":[{"op":"replace","path":"\/identifier\/interfaceLanguage","value":"occ"},{"path":"\/topicSections","value":null,"op":"add"},{"path":"\/seeAlsoSections","op":"add","value":null}],"traits":[{"interfaceLanguage":"occ"}]}]}